{
	"name": "pixeltube",
	"version": "0.0.7",
	"description": "Play videos in the terminal as colored pixel art",
	"license": "MIT",
	"author": "Mauricio Garcia de Ceca Garcia (0xMaw - maw.dev)",
	"type": "module",
	"files": ["dist"],
	"bin": {
		"pixeltube": "./dist/bin/pixeltube.js"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/mawmawmaw/pixeltube.git"
	},
	"keywords": ["youtube", "terminal", "video", "pixel-art", "cli", "tui"],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsc && chmod +x dist/bin/pixeltube.js",
		"prepare": "tsc && chmod +x dist/bin/pixeltube.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "oxlint src/ bin/ test/",
		"format": "biome format --write",
		"format:check": "biome format",
		"check": "npm run lint && npm run format:check && npm run build && npm run test",
		"release": "bash scripts/publish.sh"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/node": "^25.5.0",
		"oxlint": "^1.57.0",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	}
}
